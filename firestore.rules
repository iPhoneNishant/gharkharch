rules_version = '2';

/**
 * Firestore Security Rules for Gharkharch
 * 
 * IMPORTANT: These rules enforce read-only access from the client.
 * All writes MUST go through Cloud Functions.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId);
      // Users can create their own profile on signup
      // They can only create (not update/delete) and only for their own UID
      allow create: if isAuthenticated() 
                    && request.auth.uid == userId
                    && !exists(/databases/$(database)/documents/users/$(userId));
      // Updates and deletes must go through Cloud Functions
      allow update, delete: if false;
    }
    
    // Accounts collection
    match /accounts/{accountId} {
      // Users can read their own accounts
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // All writes go through Cloud Functions
      allow write: if false;
    }
    
    // Transactions collection
    match /transactions/{transactionId} {
      // Users can read their own transactions
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // All writes go through Cloud Functions
      allow write: if false;
    }
    
    // Recurring Transactions collection
    match /recurringTransactions/{recurringTransactionId} {
      // Users can read their own recurring transactions
      // This covers both individual reads and list queries
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // All writes go through Cloud Functions
      allow write: if false;
    }

        // SMS Account Mappings collection
    match /sms_account_mappings/{mappingId} {
      allow read, write: if true;
    }

    // Household Services collection
    match /householdServices/{serviceId} {
      // Users can read their own services
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Users can create/update/delete their own services
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Household Service Price History collection
    match /householdServicePriceHistory/{entryId} {
      // Users can read their own price history
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Users can create their own price history entries
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Users can update their own price history entries (for updating price on same date)
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false; // Price history should not be deleted
    }

    // Household Service Quantity History collection
    match /householdServiceQuantityHistory/{entryId} {
      // Users can read their own quantity history
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Users can create their own quantity history entries
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Users can update their own quantity history entries (for updating quantity on same date)
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if false; // Quantity history should not be deleted
    }

    // Household Service Daily Overrides collection
    match /householdServiceDailyOverrides/{overrideId} {
      // Users can read their own daily overrides
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Users can create/update/delete their own daily overrides
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Household Service Vacations collection
    match /householdServiceVacations/{vacationId} {
      // Users can read their own vacations
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Users can create/delete their own vacations
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
